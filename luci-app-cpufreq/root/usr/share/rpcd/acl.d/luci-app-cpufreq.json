{
	"luci-app-cpufreq": {
		"description": "Grant access to cpufreq configuration",
		"read": {
			"cgi-io": [
				"exec"
			],
			"file": [
				"/sys/devices/system/cpu/cpufreq/*",
				"/proc/interrupts"
			],
			"ubus": {
				"luci.cpufreq": [
					"get_cpu_info",
					"get_irq_status"
				],
				"uci": [
					"get"
				]
			},
			"uci": [
				"cpufreq",
				"irqbalance"
			]
		},
		"write": {
			"file": [
				"/sys/devices/virtual/thermal/*",
				"/sys/kernel/mm/lru_gen/*"
			],
			"uci": [
				"cpufreq",
				"irqbalance"
			],
			"ubus": {
				"uci": [
					"set",
					"add",
					"delete",
					"rename",
					"apply"
				]
			}
		}
	}
}